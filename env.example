# ─── Telegram ────────────────────────────────────────────────────────────────
# 1. Parle à @BotFather sur Telegram → /newbot → copie le token
TELEGRAM_TOKEN=ton_token_ici

# 2. Parle à @userinfobot sur Telegram → copie ton chat_id
TELEGRAM_CHAT_ID=ton_chat_id_ici

# ─── Google Alerts RSS ────────────────────────────────────────────────────────
# Pour chaque alerte :
# → https://www.google.com/alerts
# → Crée l'alerte → "Afficher les options" → Livraison : Flux RSS → Créer
# → Copie l'URL du flux RSS généré

ALERT_RSS_1=https://www.google.com/alerts/feeds/XXXX/XXXX
ALERT_RSS_2=https://www.google.com/alerts/feeds/XXXX/XXXX
ALERT_RSS_3=https://www.google.com/alerts/feeds/XXXX/XXXX
ALERT_RSS_4=https://www.google.com/alerts/feeds/XXXX/XXXX
ALERT_RSS_5=https://www.google.com/alerts/feeds/XXXX/XXXX
